# Copy this file to .env and fill in at least one provider key (never commit .env with real keys).
#
# **Failover order** (only providers you fill in are used, in this order):
#   Groq → Gemini → Grok (xAI) → OpenAI → OpenRouter
# On rate limits (429), bad/expired keys (401/403), or invalid key messages, the app tries the **next**
# provider automatically. Put keys for all services you use; you do not need every line.

# GROQ_API_KEY=
# Optional: GROQ_MODEL=llama-3.3-70b-versatile

# GEMINI_API_KEY=
# (Alias accepted: GOOGLE_API_KEY — same value works for the Gemini REST API in this app.)
# Optional: GEMINI_MODEL=gemini-2.0-flash

# XAI_API_KEY=
# Optional: XAI_MODEL=grok-4-1-fast-non-reasoning   (see https://docs.x.ai/docs/models — old ids like grok-2-latest are invalid)

# OPENAI_API_KEY=
# Optional: OPENAI_MODEL=gpt-4o-mini

# OPENROUTER_API_KEY=
# OpenAI-compatible gateway — https://openrouter.ai/ (one key, many models)
# Optional: OPENROUTER_MODEL=openai/gpt-4o-mini   (use slugs from their /models page, e.g. anthropic/claude-3.5-sonnet)
# Optional: OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional: OPENROUTER_HTTP_REFERER=https://localhost
# Optional: OPENROUTER_APP_NAME=AI Business Analyst

# CLI only: acceptance criteria wording in user stories — declarative (default) or bdd
# ACCEPTANCE_CRITERIA_FORMAT=declarative
# ACCEPTANCE_CRITERIA_FORMAT=bdd

# API (uvicorn): pipeline progress on stderr — each LLM step logs [START]/[END]; session logs milestones.
# Default INFO. Use DEBUG only if you need more from other libraries that respect the root logger.
# PIPELINE_LOG_LEVEL=INFO
